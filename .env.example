# OP_NET node RPC endpoint
OPNET_RPC_URL=https://testnet.opnet.org

# Deployer wallet — generate with OP_NET wallet tools
# NEVER commit your actual .env file
DEPLOYER_PRIVATE_KEY=
DEPLOYER_MLDSA_KEY=

# The OP20 token contract address you want to sell (hex, 0x...)
TOKEN_CONTRACT_ADDRESS=

# Populated automatically by deploy.mjs after deployment
TOKEN_SALE_CONTRACT_ADDRESS=
